# ============================================================================
# Triton Optimizer Configuration
# ============================================================================
# Copy this file to .env and fill in your settings

# ============================================================================
# LLM Configuration
# ============================================================================
# Model name (OpenAI format: provider/model)
LLM_MODEL=gpt-5.2

# API endpoint URL
OPENAI_API_BASE=

# API key for authentication
OPENAI_API_KEY=

# Temperature for generation (0.0-1.0, lower = more deterministic)
LLM_TEMPERATURE=1

# Maximum tokens to generate
LLM_MAX_TOKENS=50000

# ============================================================================
# Agent Configuration
# ============================================================================
# Maximum iterations per optimization stage
AGENT_MAX_ITERATIONS=3

# Use CoVeR pattern (true) or ReAct (false)
USE_COVER=true

# Agent strategy: cover, react, or hybrid
AGENT_STRATEGY=cover

# ============================================================================
# Optimization Configuration
# ============================================================================
# Maximum attempts per optimization stage
MAX_ATTEMPTS_PER_STAGE=5

# Validate correctness after each stage
VALIDATE_EACH_STAGE=true

# Require correctness preservation
REQUIRE_CORRECTNESS=true

# Target speedup (minimum acceptable)
TARGET_SPEEDUP=2.0

# ============================================================================
# Intel XPU Configuration
# ============================================================================
# Target device
XPU_DEVICE=xpu


# ============================================================================
# Logging Configuration
# ============================================================================
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Directory for log files
LOG_DIR=./outputs/logs

# Directory for saved kernels
KERNEL_DIR=./outputs/kernels

# Save intermediate optimization results
SAVE_INTERMEDIATE=true

# Skip correctness validation entirely
REQUIRE_CORRECTNESS=true

# Adjust tolerances (larger = more lenient)
CORRECTNESS_RTOL=1e-2   # relative tolerance
CORRECTNESS_ATOL=1e-5   # absolute tolerance

BEST_K=1

# ============================================================================
# Knowledge Base Configuration
# ============================================================================
# Path to knowledge base YAML files
KNOWLEDGE_DIR=./knowledge_base

# Automatically load knowledge base on startup
AUTO_LOAD_KNOWLEDGE=true

# ============================================================================
# Trial Exploration (tree-structured search over optimization trials)
# ============================================================================
# Replaces the flat BEST_K loop with a tree: each trial has a parent, the
# search policy backtracks on regression and escalates on plateau. When
# TRIAL_MAX_TRIALS is unset, the config falls back to BEST_K (or 10).

# Max number of trials in the tree (hard cap, including t0)
TRIAL_MAX_TRIALS=10

# Early-stop when global best speedup reaches this value
TRIAL_EARLY_STOP_SPEEDUP=5.0

# Plateau detection window (# trials without a new global best)
TRIAL_PLATEAU_WINDOW=2

# Search strategy: tree_walk (Triton8 default), best_first, beam, mcts
TRIAL_SEARCH=tree_walk

# Writer strategy (only stage_sequence is built in; additional writers can
# be registered via xe_forge.trials.writers.register_writer)
TRIAL_WRITER=stage_sequence

# Trial-tree state directory (relative to CWD)
TRIALS_DIR=./trials

# Finalized-kernel output directory (relative to CWD)
OUTPUT_DIR=./output

# ============================================================================
# VTune Profiling
# ============================================================================
# When enabled, the trial runner calls the profiler on plateau and feeds the
# report into OptimizerAgent.vtune_report. Skipped entirely when false.
VTUNE_ENABLED=false

# Path to the VTune binary (falls back to $VTUNE_BIN from the shell)
VTUNE_BIN=